{
  "info": {
    "name": "BookHub API Test Suite",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full endpoint test guide for BookHub API — registration, auth, and admin closed loop."
  },
