  "item": [
    {
      "name": "Phase 1 — New User Registration",
      "item": [
        {
          "name": "1.1 Register New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/account/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "account",
                "register"
              ]
            },
            "description": "Registers a new user. A verification email is sent to the provided address.",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 OK\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Success message returned\", () => {",
                  "  pm.expect(pm.response.text()).to.include(\"registered successfully\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Verify Email (paste full URL from email)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/account/verify-email?userId=PASTE_USER_ID_HERE&token=PASTE_TOKEN_HERE",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "account",
                "verify-email?userId=PASTE_USER_ID_HERE&token=PASTE_TOKEN_HERE"
              ]
            },
            "description": "Paste the full URL from the verification email into the address bar. Replace the userId and token query params with those from the email.",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 OK\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Verification successful\", () => {",
                  "  pm.expect(pm.response.text()).to.include(\"verification successful\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Login as New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/account/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "account",
                "login"
              ]
            },
            "description": "Logs in and auto-saves the JWT to the collection variable 'new_user_token'.",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 OK\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Token returned and saved\", () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property(\"token\");",
                  "  pm.collectionVariables.set(\"new_user_token\", json.token);",
                  "  console.log(\"new_user_token saved:\", json.token.substring(0, 30) + \"...\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.4 Attempt Admin-Only Endpoint (Expect 403)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/reviews",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reviews"
              ]
            },
            "description": "GET /api/reviews requires Admin role. A regular user JWT returns 403 Forbidden — auth succeeds but authorisation fails.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{new_user_token}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 403 Forbidden\", () => pm.response.to.have.status(403));",
                  "pm.test(\"Role-based access control is working\", () => {",
                  "  pm.expect(pm.response.code).to.equal(403);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Phase 2 — Admin Authentication",
