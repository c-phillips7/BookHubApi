    {
      "key": "base_url",
      "value": "https://bookhub-7cs4.onrender.com",
      "type": "string"
    },
    {
      "key": "new_user_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "genre_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "author_id",
      "value": "",
      "type": "string"
    },
    {
