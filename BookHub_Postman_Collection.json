          { "key": "Authorization", "value": "Bearer {{USER_JWT}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookId\": 2,\n  \"status\": \"WantToRead\"\n}",
          "options": { "raw": { "language": "json" } }
