{
  "info": {
    "name": "BookHub API Test Collection",
    "_postman_id": "d4f9e3a2-1c4a-4b3f-8e2b-0a2e7d5f4b1c",
    "description": "Full battery of test requests for BookHub API (CRUD endpoints for Books, Authors, Genres, ReadingLists, Reviews) with JWT placeholders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Books",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{USER_JWT}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:5000/api/books",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","books"]
        }
      },
      "response": []
    },
    {
      "name": "Create Book (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "Authorization", "value": "Bearer {{ADMIN_JWT}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"The Hobbit\",\n  \"description\": \"A prequel to The Lord of the Rings\",\n  \"authorId\": 3,\n  \"genreIds\": [1,2]\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "http://localhost:5000/api/books",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","books"]
        }
      },
      "response": []
    },
    {
