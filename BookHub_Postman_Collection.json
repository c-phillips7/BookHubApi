        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Fantasy Favorites\",\n  \"description\": \"Books I want to read\",\n  \"isPublic\": true\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "http://localhost:5000/api/readinglists",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api","readinglists"]
        }
      },
      "response": []
    },
