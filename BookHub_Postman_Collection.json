        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" },
          { "key": "Authorization", "value": "Bearer {{USER_JWT}}", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookId\": 1,\n  \"content\": \"Absolutely loved it!\",\n  \"rating\": 5\n}",
